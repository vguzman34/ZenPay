# ===========================================
# ZenPay - Variables de Entorno
# Copia este archivo como .env y completa
# ===========================================

# --- Backend (Railway/Render) ---
SPRING_PROFILES_ACTIVE=prod

# Base de datos PostgreSQL (Railway provee la URL automáticamente)
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:5432/zenpay
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<password>

# JWT - Generar secreto con: openssl rand -base64 64
JWT_SECRET=<generar-secreto-seguro-de-256-bits>
JWT_ACCESS_TOKEN_EXPIRATION=86400000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# CORS - Dominios permitidos (separados por coma)
APP_CORS_ALLOWED_ORIGINS=https://zenpay.vercel.app,https://www.zenpay.app

# --- Frontend (Vercel) ---
# Se configura en el dashboard de Vercel, no en .env local
# ANGULAR_API_URL=https://zenpay-api.onrender.com/api/v1
